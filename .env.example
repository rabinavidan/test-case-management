# Copy this file to .env and fill in real values. .env is git-ignored — never commit real secrets.

# --- Database (optional) ---
# Leave unset for local dev: falls back to a local SQLite file (testcases.db).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# POSTGRES_URL=postgresql://user:password@host:5432/dbname

# --- Auth ---
# HMAC signing key for JWTs (api/auth.py). Falls back to an insecure dev default if unset —
# always set a real random value in any deployed environment.
JWT_SECRET_KEY=change-me-to-a-long-random-value

# --- Admin seeding (optional, api/main.py _seed_admin) ---
# If set, an admin user with these credentials is created/updated on every cold start.
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_EMAIL=

# --- AI test-case generation (optional, api/main.py) ---
# Needed only for the "generate test cases with AI" suite endpoint.
# ANTHROPIC_API_KEY=

# --- E2E tests (tests/pages/base_page.py, tests/test_login_e2e.py) ---
# Credentials used by Playwright E2E tests to log in against --base-url. Point these at a
# real, non-production, low-privilege test account — never a production admin.
E2E_USERNAME=
E2E_EMAIL=
E2E_PASSWORD=
